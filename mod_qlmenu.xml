<?xml version="1.0" encoding="utf-8"?>
<extension type="module" client="site" method="upgrade">
    <name>MOD_QLMENU_TITLE</name>
    <creationDate>2026-03-14</creationDate>
    <author>Mareike Riegel</author>
    <authorEmail>info@ql.de</authorEmail>
    <authorUrl>https://ql.de</authorUrl>
    <copyright>Copyright (C) 2026 Mareike Riegel. All rights reserved.</copyright>
    <license>GNU General Public License version 2 or later;</license>
    <version>1.0.0</version>
    <updateservers>
        <server type="extension" priority="1" name="qlmenu - Updates">https://raw.githubusercontent.com/hoochicken/mod_qlmenu/refs/heads/main/_jupdate/mod_qlmenu.xml</server>
    </updateservers>
    <description><![CDATA[MOD_QLMENU_XML_DESCRIPTION]]></description>
    <namespace path="src">Hoochicken\Module\Qlmenu</namespace>
    <files>
        <folder module="mod_qlmenu">services</folder>
        <folder>_jupdate</folder>
        <folder>language</folder>
        <folder>media</folder>
        <folder>services</folder>
        <folder>src</folder>
        <folder>tmpl</folder>
        <file>mod_qlmenu.xml</file>
        <file>LICENSE.txt</file>
        <file>README.md</file>
    </files>
    <media destination="mod_qlmenu" folder="media">
        <filename>joomla.asset.json</filename>
        <folder>css</folder>
        <filename>css/style.css</filename>
        <folder>js</folder>
        <filename>js/script.js</filename>
    </media>
    <languages>
        <language tag="en-GB">language/en-GB/mod_qlmenu.ini</language>
        <language tag="en-GB">language/en-GB/mod_qlmenu.sys.ini</language>
    </languages>
    <config>
        <fields name="params">
            <fieldset name="basic" addfieldprefix="Joomla\Component\Menus\Administrator\Field">
                <field
                        name="menutype"
                        type="menu"
                        label="MOD_QLMENU_MENUTYPE_LABEL"
                        clientid="0"
                />

                <field
                        name="base"
                        type="modal_menu"
                        label="MOD_QLMENU_ACTIVE_LABEL"
                        select="true"
                        new="true"
                        edit="true"
                        clear="true"
                        filter="integer"
                >
                    <option value="">JCURRENT</option>
                </field>

                <field
                        name="startLevel"
                        type="list"
                        label="MOD_QLMENU_STARTLEVEL_LABEL"
                        default="1"
                        filter="integer"
                        validate="options"
                >
                    <option value="1">J1</option>
                    <option value="2">J2</option>
                    <option value="3">J3</option>
                    <option value="4">J4</option>
                    <option value="5">J5</option>
                    <option value="6">J6</option>
                    <option value="7">J7</option>
                    <option value="8">J8</option>
                    <option value="9">J9</option>
                    <option value="10">J10</option>
                </field>

                <field
                        name="endLevel"
                        type="list"
                        label="MOD_QLMENU_ENDLEVEL_LABEL"
                        default="0"
                        filter="integer"
                        validate="options"
                >
                    <option value="0">JALL</option>
                    <option value="1">J1</option>
                    <option value="2">J2</option>
                    <option value="3">J3</option>
                    <option value="4">J4</option>
                    <option value="5">J5</option>
                    <option value="6">J6</option>
                    <option value="7">J7</option>
                    <option value="8">J8</option>
                    <option value="9">J9</option>
                    <option value="10">J10</option>
                </field>

                <field
                        name="showAllChildren"
                        type="radio"
                        layout="joomla.form.field.radio.switcher"
                        label="MOD_QLMENU_ALLCHILDREN_LABEL"
                        default="1"
                        filter="integer"
                >
                    <option value="0">JHIDE</option>
                    <option value="1">JSHOW</option>
                </field>
            </fieldset>

            <fieldset name="styles_1st_level">
                <field
                        name="level_1st_color"
                        type="color"
                        label="MOD_QLMENU_COLOR_LABEL"
                        default="#000000"
                />
                <field
                        name="level_1st_background_color"
                        type="color"
                        label="MOD_QLMENU_BG_COLOR_LABEL"
                        default="#ffffff"
                />
                <field
                        name="level_1st_color_hover"
                        type="color"
                        label="MOD_QLMENU_COLOR_HOVER_LABEL"
                        default="#000000"
                />
                <field
                        name="level_1st_background_color_hover"
                        type="color"
                        label="MOD_QLMENU_BG_COLOR_HOVER_LABEL"
                        default="#eeeeee"
                />
                <field
                        name="level_1st_color_active"
                        type="color"
                        label="MOD_QLMENU_COLOR_ACTIVE_LABEL"
                        default="#000000"
                />
                <field
                        name="level_1st_background_color_active"
                        type="color"
                        label="MOD_QLMENU_BG_COLOR_ACTIVE_LABEL"
                        default="#ff8800"
                />
                <field
                        name="level_1st_padding"
                        type="text"
                        label="MOD_QLMENU_PADDING_LABEL"
                        default="0.5rem 0.75rem"
                />
                <field
                        name="level_1st_font_size"
                        type="list"
                        label="MOD_QLMENU_FONT_SIZE_LABEL"
                        default="1rem"
                >
                    <option value="4.8rem">2.8rem</option>
                    <option value="4.7rem">2.7rem</option>
                    <option value="4.6rem">2.6rem</option>
                    <option value="4.5rem">2.5rem</option>
                    <option value="4.4rem">2.4rem</option>
                    <option value="4.3rem">2.3rem</option>
                    <option value="4.2rem">2.2rem</option>
                    <option value="4.1rem">2.1rem</option>
                    <option value="4.0rem">2.0rem</option>
                    <option value="3.9rem">1.9rem</option>
                    <option value="3.8rem">1.8rem</option>
                    <option value="3.7rem">1.7rem</option>
                    <option value="3.6rem">1.6rem</option>
                    <option value="3.5rem">1.5rem</option>
                    <option value="3.4rem">1.4rem</option>
                    <option value="3.3rem">1.3rem</option>
                    <option value="3.2rem">1.2rem</option>
                    <option value="3.1rem">1.1rem</option>
                    <option value="3.0rem">1.0rem</option>
                    <option value="2.8rem">2.8rem</option>
                    <option value="2.7rem">2.7rem</option>
                    <option value="2.6rem">2.6rem</option>
                    <option value="2.5rem">2.5rem</option>
                    <option value="2.4rem">2.4rem</option>
                    <option value="2.3rem">2.3rem</option>
                    <option value="2.2rem">2.2rem</option>
                    <option value="2.1rem">2.1rem</option>
                    <option value="2.0rem">2.0rem</option>
                    <option value="1.9rem">1.9rem</option>
                    <option value="1.8rem">1.8rem</option>
                    <option value="1.7rem">1.7rem</option>
                    <option value="1.6rem">1.6rem</option>
                    <option value="1.5rem">1.5rem</option>
                    <option value="1.4rem">1.4rem</option>
                    <option value="1.3rem">1.3rem</option>
                    <option value="1.2rem">1.2rem</option>
                    <option value="1.1rem">1.1rem</option>
                    <option value="1.0rem">1.0rem</option>
                </field>
            </fieldset>

            <fieldset name="styles_2nd_level">
                <field
                        name="level_2nd_color"
                        type="color"
                        label="MOD_QLMENU_COLOR_LABEL"
                        default="#000000"
                />
                <field
                        name="level_2nd_background_color"
                        type="color"
                        label="MOD_QLMENU_BG_COLOR_LABEL"
                        default="#eeeeee"
                />
                <field
                        name="level_2nd_color_hover"
                        type="color"
                        label="MOD_QLMENU_COLOR_HOVER_LABEL"
                        default="#000000"
                />
                <field
                        name="level_2nd_background_color_hover"
                        type="color"
                        label="MOD_QLMENU_BG_COLOR_HOVER_LABEL"
                        default="#ec5800"
                />
                <field
                        name="level_2nd_color_active"
                        type="color"
                        label="MOD_QLMENU_COLOR_ACTIVE_LABEL"
                        default="#000000"
                />
                <field
                        name="level_2nd_background_color_active"
                        type="color"
                        label="MOD_QLMENU_BG_COLOR_ACTIVE_LABEL"
                        default="#ff8800"
                />
                <field
                        name="level_2nd_padding"
                        type="text"
                        label="MOD_QLMENU_PADDING_LABEL"
                        default="0.35rem 0.6rem"
                />
                <field
                        name="level_2nd_font_size"
                        type="list"
                        label="MOD_QLMENU_FONT_SIZE_LABEL"
                        default="1rem"
                >
                    <option value="4.8rem">2.8rem</option>
                    <option value="4.7rem">2.7rem</option>
                    <option value="4.6rem">2.6rem</option>
                    <option value="4.5rem">2.5rem</option>
                    <option value="4.4rem">2.4rem</option>
                    <option value="4.3rem">2.3rem</option>
                    <option value="4.2rem">2.2rem</option>
                    <option value="4.1rem">2.1rem</option>
                    <option value="4.0rem">2.0rem</option>
                    <option value="3.9rem">1.9rem</option>
                    <option value="3.8rem">1.8rem</option>
                    <option value="3.7rem">1.7rem</option>
                    <option value="3.6rem">1.6rem</option>
                    <option value="3.5rem">1.5rem</option>
                    <option value="3.4rem">1.4rem</option>
                    <option value="3.3rem">1.3rem</option>
                    <option value="3.2rem">1.2rem</option>
                    <option value="3.1rem">1.1rem</option>
                    <option value="3.0rem">1.0rem</option>
                    <option value="2.8rem">2.8rem</option>
                    <option value="2.7rem">2.7rem</option>
                    <option value="2.6rem">2.6rem</option>
                    <option value="2.5rem">2.5rem</option>
                    <option value="2.4rem">2.4rem</option>
                    <option value="2.3rem">2.3rem</option>
                    <option value="2.2rem">2.2rem</option>
                    <option value="2.1rem">2.1rem</option>
                    <option value="2.0rem">2.0rem</option>
                    <option value="1.9rem">1.9rem</option>
                    <option value="1.8rem">1.8rem</option>
                    <option value="1.7rem">1.7rem</option>
                    <option value="1.6rem">1.6rem</option>
                    <option value="1.5rem">1.5rem</option>
                    <option value="1.4rem">1.4rem</option>
                    <option value="1.3rem">1.3rem</option>
                    <option value="1.2rem">1.2rem</option>
                    <option value="1.1rem">1.1rem</option>
                    <option value="1.0rem">1.0rem</option>
                </field>
            </fieldset>

            <fieldset name="advanced">
                <field
                        name="tag_id"
                        type="text"
                        label="MOD_QLMENU_TAG_ID_LABEL"
                />

                <field
                        name="class_sfx"
                        type="text"
                        label="MOD_QLMENU_CLASS_LABEL"
                        validate="CssIdentifier"
                />

                <field
                        name="window_open"
                        type="text"
                        label="MOD_QLMENU_TARGET_LABEL"
                        description="MOD_QLMENU_TARGET_DESC"
                />

                <field
                        name="layout"
                        type="modulelayout"
                        label="JALT_LAYOUT_LABEL"
                        class="form-select"
                        default="_:default"
                        validate="moduleLayout"
                />

                <field
                        name="moduleclass_sfx"
                        type="textarea"
                        label="COM_MODULES_MODULECLASS_SFX_LABEL"
                        rows="3"
                        validate="CssIdentifier"
                />

                <field
                        name="cache"
                        type="list"
                        label="COM_MODULES_CACHING_LABEL"
                        default="1"
                        filter="integer"
                        validate="options"
                >
                    <option value="1">JGLOBAL_USE_GLOBAL</option>
                    <option value="0">COM_MODULES_VALUE_NOCACHING</option>
                </field>

                <field
                        name="cache_time"
                        type="number"
                        label="COM_MODULES_CACHE_TIME_LABEL"
                        default="900"
                        filter="integer"
                />

                <field
                        name="cachemode"
                        type="hidden"
                        default="itemid"
                >
                    <option value="itemid"></option>
                </field>
            </fieldset>
        </fields>
    </config>
</extension>
